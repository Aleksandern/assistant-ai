OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-5-mini
OPENAI_FILE_ID=4FSDS3GH1K1Nd7hh5RHDEPRwBa

# Default instructions for plain OpenAI text replies in one-off reply generation.
# Used by python/modules/openai_reply_generator.py when explicit instructions are not passed.
OPENAI_REPLY_INSTRUCTIONS="Reply like a real person in a normal conversation, etc..."

# Developer instructions for initializing a long-lived OpenAI interview conversation.
# Used by python/modules/openai_conversation_initializer.py.
OPENAI_CONVERSATION_INSTRUCTIONS="Answer as me in a real live conversation, in first person, etc...."

# User message text sent together with the attached DOCX file during conversation initialization.
# Used by python/modules/openai_conversation_initializer.py.
OPENAI_CONVERSATION_FILE_MESSAGE="This attached DOCX file is etc..."

# Template for the optional topic-hint message during conversation initialization.
# Must contain the {topic_hint} placeholder exactly once.
OPENAI_CONVERSATION_TOPIC_HINT_TEMPLATE="Conversation topic hint: {topic_hint}"

# Default instructions for continuing an existing OpenAI conversation.
# Used by python/modules/openai_conversation_reply_generator.py when explicit turn instructions are not passed.
OPENAI_CONVERSATION_REPLY_INSTRUCTIONS="If the latest conversation message is in Russian, answer in Russian. Otherwise answer in English. etc..."

# Prompt for screenshot-based task solving through OpenAI.
# Used by python/modules/task_openai_solver.py.
OPENAI_TASK_SOLVER_PROMPT="You are experienced etc...."

# Optional service tier. Leave unset for default behavior.
# Supported values: priority
OPENAI_SERVICE_TIER=priority

# Optional reply length cap. Leave unset to keep default behavior.
# Positive integer only, for example 120.
OPENAI_MAX_OUTPUT_TOKENS=120

# Optional thresholds for considering streamed reply text "useful".
# The useful-text timestamp is recorded when either threshold is reached.
OPENAI_FIRST_USEFUL_TEXT_MIN_CHARS=24
OPENAI_FIRST_USEFUL_TEXT_MIN_WORDS=4

# Optional prompt caching for repeated conversation prefixes.
# Supported values: true, false
OPENAI_PROMPT_CACHE_ENABLED=true
# Optional cache key prefix. Defaults to assistantai.
OPENAI_PROMPT_CACHE_KEY_PREFIX=assistantai
# Optional cache retention.
# Supported values: in-memory, in_memory, 24h
OPENAI_PROMPT_CACHE_RETENTION=24h
